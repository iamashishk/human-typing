{
  "name": "human-typing",
  "version": "0.5.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A playwright utility for human-like typing simulation with natural delays, typos and real keyboard events.",
  "keywords": [
    "human-typing",
    "playwright",
    "type",
    "typing",
    "human",
    "human-like",
    "keyboard",
    "playwright-type",
    "automation",
    "anti-bot",
    "form-filling",
    "input",
    "playwright-plugin"
  ],
  "homepage": "https://github.com/iamashishk/human-typing#readme",
  "bugs": {
    "url": "https://github.com/iamashishk/human-typing/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iamashishk/human-typing.git"
  },
  "license": "MIT",
  "author": "iamashishk",
  "type": "commonjs",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "test": "npm run build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npm run format:check && npm run build && npm run test",
    "precommit": "npm run format:check"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.29.6",
    "@eslint/js": "^9.34.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.3.0",
    "prettier": "3.6.2",
    "playwright": "^1.61.1",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
